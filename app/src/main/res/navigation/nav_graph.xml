<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@+id/LauncherFragment">

    <fragment
        android:id="@+id/LauncherFragment"
        android:name="com.qch.sumelauncher.fragment.LauncherFragment"
        android:label="">

        <action
            android:id="@+id/action_Launcher_to_Drawer"
            app:destination="@+id/DrawerFragment"
            app:enterAnim="@anim/nav_default_enter_anim"
            app:exitAnim="@anim/nav_default_exit_anim" />

        <action
            android:id="@+id/action_Launcher_to_Settings"
            app:destination="@id/SettingsFragment"
            app:enterAnim="@anim/nav_default_enter_anim"
            app:exitAnim="@anim/nav_default_exit_anim" />
    </fragment>

    <fragment
        android:id="@+id/DrawerFragment"
        android:name="com.qch.sumelauncher.drawer.DrawerFragment"
        android:label="" />

    <fragment
        android:id="@+id/SettingsFragment"
        android:name="com.qch.sumelauncher.fragment.SettingsFragment"
        android:label="@string/settings">

        <action
            android:id="@+id/action_Settings_to_Permission"
            app:destination="@+id/PermissionFragment"
            app:enterAnim="@anim/nav_default_enter_anim"
            app:exitAnim="@anim/nav_default_exit_anim" />
    </fragment>

    <fragment
        android:id="@+id/PermissionFragment"
        android:name="com.qch.sumelauncher.fragment.PermissionFragment"
        android:label="@string/permission" />
</navigation>